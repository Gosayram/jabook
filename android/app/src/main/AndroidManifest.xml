<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:installLocation="auto">

    <!-- Network permissions (API 21+) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- Required only if your app modifies network configuration -->
    <!-- <uses-permission android:name="android.permission.CHANGE_NETWORK_STATE" /> -->

    <!-- Storage permissions for both internal and SD card access -->
    <!-- READ_EXTERNAL_STORAGE: Required for reading files from internal storage and SD card -->
    <!-- Works on Android 6.0+ (API 23+) as runtime permission -->
    <!-- Keep without maxSdkVersion for SD card compatibility on all Android versions -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- WRITE_EXTERNAL_STORAGE: Required for writing files to internal storage and SD card -->
    <!-- Works on Android 6.0+ (API 23+) as runtime permission -->
    <!-- Keep without maxSdkVersion for SD card write access on all Android versions -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- MANAGE_EXTERNAL_STORAGE: Required for full filesystem access on Android 11+ (API 30+) -->
    <!-- Allows access to all files on internal storage and SD card -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Modern scoped media permissions (Android 13+, API 33+) -->
    <!-- These replace READ_EXTERNAL_STORAGE for media files on Android 13+ -->
    <!-- Audio-only permission is enough for audio playback apps -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <!-- Uncomment if you really access images or videos -->
    <!-- <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" /> -->
    <!-- <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" /> -->

    <!-- Notification permission (Android 13+, API 33+) -->
    <!-- Required for showing notifications on Android 13+ -->
    <!-- On Android 12 and below, notifications work without explicit permission -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- SCHEDULE_EXACT_ALARM: Required for exact alarm scheduling (background downloads, etc) -->
    <!-- Android 12+ (API 31+) requires this for WorkManager and AlarmManager exact alarms -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- VIBRATE: Allows notifications to vibrate -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- READ_PHONE_STATE: Required for automatic resume after phone calls -->
    <!-- Allows PhoneStateListener to detect when calls end and resume playback -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- RECORD_AUDIO: Required for audio visualizer to capture audio data -->
    <!-- Android Visualizer API needs this permission to access audio session -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Power and audio service permissions -->
    <!-- WAKE_LOCK: Prevents device from sleeping during audio playback (API 21+) -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- FOREGROUND_SERVICE: Required for foreground services (Android 9+, API 28+) -->
    <!-- Note: On Android 9+ (API 28+), foreground services require this permission -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />

    <!-- Required for Android 14+ (API 34+) when using media playback foreground services -->
    <!-- This is a more specific permission for media playback foreground services -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Required for Android 14+ (API 34+) when using data sync foreground services -->
    <!-- This is for download/upload tasks in foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <!-- Required for Android 15+ (API 35+) when using media processing foreground services -->
    <!-- This is for audio conversion/transcoding tasks in foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROCESSING" />

    <!-- Optional: requesting battery optimization exemption requires strict justification -->
    <!-- This permission is rarely approved by Google Play and should be avoided -->
    <!-- <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" /> -->

    <!-- Hardware features - mark as optional for better device compatibility -->
    <!-- Allows app to run on Android TV, tablets without touchscreen, etc -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.wifi"
        android:required="false" />
    <!-- Leanback for Android TV - optional so app works on phones too -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="false" />

    <application
        android:name=".JabookApplication"
        android:label="jabook"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config"
        android:allowBackup="true"
        android:hasFragileUserData="true"
        android:enableOnBackInvokedCallback="true"
        android:largeHeap="true"
        android:supportsRtl="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:manageSpaceActivity=".DataManagementActivity"
        tools:targetApi="34"
        tools:ignore="NamespaceTypo,MissingClass">

        <!-- Android Auto support - enables audiobook playback in cars -->
        <!-- Users can browse library, control playback with steering wheel, use voice commands -->
        <meta-data
            android:name="com.google.android.gms.car.application"
            android:resource="@xml/auto_app_desc" />


        <!-- requestLegacyExternalStorage removed: not supported on Android 11+ (API 30+) -->
        <!-- App uses app-specific directory which doesn't require this attribute -->
        <!-- App-specific directory path: /storage/emulated/0/Android/data/com.jabook.app.jabook/files/JabookAudio -->

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize"
            android:autofillHints="username,password">

            <!-- LAUNCHER intent-filter moved to ComposeMainActivity -->
        </activity>

        <!-- Compose UI Activity - NOW THE MAIN LAUNCHER -->
        <activity
            android:name=".compose.ComposeMainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/Theme.App.Starting"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- MAIN LAUNCHER - App now starts with Compose, not Flutter -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Magnet link deep links for torrent downloads -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="magnet" />
            </intent-filter>

            <!-- Open external audio files in shared playback pipeline -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
                <data android:scheme="content" />
                <data android:scheme="file" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="audio/*" />
            </intent-filter>

            <!-- Custom jabook:// scheme for app-specific deep links -->
            <!-- Examples: jabook://library, jabook://player/bookId, jabook://settings -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data
                    android:scheme="jabook"
                    android:host="*" />
            </intent-filter>
        </activity>

        <!-- Data Management Activity for storage management -->
        <!-- This activity is called by the system when user wants to manage app storage -->
        <!-- Required for apps that use MANAGE_EXTERNAL_STORAGE permission -->
        <activity
            android:name=".DataManagementActivity"
            android:exported="true"
            android:theme="@style/Theme.Transparent"
            tools:ignore="LockedOrientationActivity" />

        <!-- Crash Handler Activity -->
        <!-- Runs in a separate process to ensure it can display even if the main app process is corrupted -->
        <activity
            android:name=".crash.CrashActivity"
            android:process=":crash"
            android:theme="@style/Theme.App.Starting"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true" />

        <!-- Android TV Main Activity -->
        <!-- Uses Leanback library for 10-foot UI experience -->
        <activity
            android:name=".tv.TvActivity"
            android:exported="true"
            android:theme="@style/Theme.App.Starting"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Android TV Player Activity -->
        <activity
            android:name=".tv.TvPlayerActivity"
            android:exported="false"
            android:theme="@style/Theme.App.Starting"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode" />

        <!-- Native Media3 audio player service -->
        <service
            android:name=".audio.AudioPlayerService"
            android:exported="true"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="android.media.browse.MediaBrowserService" />
                <!-- Media3 session service support -->
                <action android:name="androidx.media3.session.MediaSessionService" />
                <action android:name="androidx.media3.session.MediaLibraryService" />
                <action android:name="android.media.action.MEDIA_PLAY_FROM_SEARCH" />
            </intent-filter>
        </service>

        <!-- Media3 MediaButtonReceiver - handles media button intents from headsets/Bluetooth -->
        <receiver android:name="androidx.media3.session.MediaButtonReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MEDIA_BUTTON" />
            </intent-filter>
        </receiver>

        <!-- Download foreground service -->
        <service
            android:name=".download.DownloadForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync">
        </service>

        <!-- Torrent download foreground service -->
        <service
            android:name=".compose.data.torrent.TorrentDownloadService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Indexing foreground service -->
        <service
            android:name=".indexing.IndexingForegroundService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Torrent notification action receiver -->
        <receiver
            android:name=".compose.receiver.TorrentActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="org.jabook.ACTION_PAUSE_TORRENT" />
                <action android:name="org.jabook.ACTION_RESUME_TORRENT" />
                <action android:name="org.jabook.ACTION_STOP_TORRENT" />
                <action android:name="org.jabook.ACTION_CANCEL_TORRENT" />
                <action android:name="org.jabook.ACTION_PAUSE_ALL" />
                <action android:name="org.jabook.ACTION_RESUME_ALL" />
            </intent-filter>
        </receiver>

        <!-- MediaSession action receiver for Play/Pause commands -->
        <!-- This receiver handles Play/Pause actions through MediaSession, -->
        <!-- which is more reliable than PendingIntent on Samsung and other devices -->
        <receiver
            android:name=".audio.MediaSessionActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.jabook.app.jabook.audio.MEDIA_SESSION_PLAY" />
                <action android:name="com.jabook.app.jabook.audio.MEDIA_SESSION_PAUSE" />
            </intent-filter>
        </receiver>

        <!-- Player widget provider -->
        <receiver
            android:name=".widget.PlayerWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.jabook.app.jabook.UPDATE_WIDGET" />
                <action android:name="com.jabook.app.jabook.PLAYBACK_STATE_CHANGED" />
                <action android:name="com.jabook.app.jabook.MEDIA_ITEM_CHANGED" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/player_widget_info" />
        </receiver>

        <!-- Disable default WorkManager initialization -->
        <!-- App uses on-demand initialization via Configuration.Provider -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- FileProvider for secure file sharing -->
        <!-- Allows sharing torrent files, APKs, logs, and audiobooks with other apps -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- preloaded_fonts removed: Not needed for Compose with Google Fonts -->
        <!-- Google Fonts are loaded dynamically via FontUtils, no preloading required -->
    </application>

    <!-- Queries required for url_launcher, PROCESS_TEXT, and SAF usage -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>

        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>

        <!-- Storage Access Framework (SAF) queries for folder selection on Android 11+ -->
        <intent>
            <action android:name="android.intent.action.OPEN_DOCUMENT_TREE" />
        </intent>
        <intent>
            <action android:name="android.intent.action.OPEN_DOCUMENT" />
        </intent>
    </queries>

</manifest>
