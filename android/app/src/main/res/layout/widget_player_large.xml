<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top row: Cover + Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Cover image -->
        <ImageView
            android:id="@+id/widget_cover"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/no_book_playing"
            android:layout_marginEnd="16dp" />

        <!-- Book info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_book_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_book_playing"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_book_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="4dp"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:layout_marginTop="16dp"
        android:max="1000"
        android:progress="0"
        android:progressTint="?android:attr/colorAccent" />

    <!-- Time labels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/widget_time_current"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0:00"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/widget_time_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0:00"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Main control buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="16dp">

        <ImageButton
            android:id="@+id/widget_previous"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_skip_previous"
            android:contentDescription="@string/previousChapter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="14dp" />

        <ImageButton
            android:id="@+id/widget_play_pause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_play"
            android:contentDescription="@string/play"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="18dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp" />

        <ImageButton
            android:id="@+id/widget_next"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_skip_next"
            android:contentDescription="@string/nextChapter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="14dp" />
    </LinearLayout>

    <!-- Secondary control buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp">

        <ImageButton
            android:id="@+id/widget_speed"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_speed"
            android:contentDescription="@string/playbackSpeed"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="12dp" />

        <ImageButton
            android:id="@+id/widget_repeat"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_repeat"
            android:contentDescription="@string/noRepeat"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:layout_marginStart="8dp" />

        <ImageButton
            android:id="@+id/widget_timer"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_timer"
            android:contentDescription="@string/sleepTimer"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:layout_marginStart="8dp" />
    </LinearLayout>
</LinearLayout>

