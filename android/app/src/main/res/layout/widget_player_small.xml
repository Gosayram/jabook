<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_content"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="10dp">

    <!-- Cover + Info row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Cover image -->
        <ImageView
            android:id="@+id/widget_cover"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/no_book_playing"
            android:layout_marginEnd="10dp" />

        <!-- Book info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_book_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_book_playing"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_book_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/widget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_marginTop="8dp"
        android:max="1000"
        android:progress="0"
        android:progressTint="?android:attr/colorAccent" />

    <!-- Control buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="8dp">

        <ImageButton
            android:id="@+id/widget_previous"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_skip_previous"
            android:contentDescription="@string/previousChapter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="10dp" />

        <ImageButton
            android:id="@+id/widget_play_pause"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_play"
            android:contentDescription="@string/play"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp" />

        <ImageButton
            android:id="@+id/widget_next"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_skip_next"
            android:contentDescription="@string/nextChapter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="10dp" />
    </LinearLayout>
</LinearLayout>

