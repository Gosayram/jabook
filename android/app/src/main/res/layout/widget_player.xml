<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_content"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?android:attr/selectableItemBackground">

    <!-- Cover image as background with transparency -->
    <ImageView
        android:id="@+id/widget_cover"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.3"
        android:contentDescription="@string/no_book_playing" />

    <!-- Content overlay -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#80000000">

        <!-- Main content row: Info + Controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

        <!-- Book info and progress -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Book title -->
            <TextView
                android:id="@+id/widget_book_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_book_playing"
                android:textColor="?android:attr/textColorPrimary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Book author -->
            <TextView
                android:id="@+id/widget_book_author"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Progress bar -->
            <ProgressBar
                android:id="@+id/widget_progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginTop="8dp"
                android:max="1000"
                android:progress="0"
                android:progressTint="?android:attr/colorAccent" />

            <!-- Time labels -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/widget_time_current"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0:00"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_time_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Control buttons row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp">

        <!-- Previous button -->
        <ImageButton
            android:id="@+id/widget_previous"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_skip_previous"
            android:contentDescription="@string/previousChapter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="12dp" />

        <!-- Play/Pause button -->
        <ImageButton
            android:id="@+id/widget_play_pause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_play"
            android:contentDescription="@string/play"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="12dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp" />

        <!-- Next button -->
        <ImageButton
            android:id="@+id/widget_next"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_skip_next"
            android:contentDescription="@string/nextChapter"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="12dp" />

        <!-- Speed button -->
        <ImageButton
            android:id="@+id/widget_speed"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_speed"
            android:contentDescription="@string/playbackSpeed"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_marginStart="8dp" />

        <!-- Repeat button -->
        <ImageButton
            android:id="@+id/widget_repeat"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_repeat"
            android:contentDescription="@string/noRepeat"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_marginStart="4dp" />

        <!-- Timer button -->
        <ImageButton
            android:id="@+id/widget_timer"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_timer"
            android:contentDescription="@string/sleepTimer"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:layout_marginStart="4dp" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
