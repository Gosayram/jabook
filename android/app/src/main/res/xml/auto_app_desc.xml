<!--
  Android Auto application descriptor.
  This tells Android Auto that Jabook supports media playback in cars.
  
  Users can now:
  - Browse audiobook library from car's infotainment system
  - Control playback with steering wheel buttons
  - Use voice commands: "Hey Google, play [audiobook name]"
  - Safe, driver-friendly UI optimized for cars
-->
<automotiveApp>
  <uses name="media" />
</automotiveApp>
